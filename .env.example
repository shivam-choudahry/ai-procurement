# ==========================================
# Azure OpenAI Configuration
# ==========================================
AZURE_API_BASE=
AZURE_API_KEY=
AZURE_API_VERSION=
AZURE_DEPLOYMENT=

# ==========================================
# Langfuse (Optional)
# ==========================================
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# ==========================================
# FastAPI Backend
# ==========================================
BACKEND_URL=http://localhost:8000

# ==========================================
# Application Settings
# ==========================================
LOG_LEVEL=INFO
DEMO_MODE=true

# ==========================================
# OpenAI (Optional - use instead of Azure)
# Uncomment if not using Azure OpenAI
# ==========================================
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o